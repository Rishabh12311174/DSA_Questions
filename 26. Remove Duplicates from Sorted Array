class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        auto it = unique(nums.begin(), nums.end());
        return it-nums.begin();
        
    }
};
//-------------------------------------------------------------------------------------------------------------
//2nd approch
class Solution 
{
public:
    int removeDuplicates(vector<int>& nums) 
    {
      if(nums.empty()) return 0;
      int i= 0, j= 1;
      while(j<nums.size())
      {
        if(nums[i]!= nums[j])
        {
            i++;
            nums[i] = nums[j];
        }
        j++;
        }
        return i+1;
      }
    
};
